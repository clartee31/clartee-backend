{
  "version": 2,
  "functions": {
    "api/chat.js": {
      "memory": 128,
      "maxDuration": 15
    },
    "api/login.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
